# Example remote backend configuration for a real prod deployment.
# Not used by default (see versions.tf, which uses a local backend so this
# assessment can be validated without AWS credentials).
#
# To use: terraform init -backend-config=backend.hcl -reconfigure
# (after replacing the "local" backend block in versions.tf with `backend "s3" {}`)

bucket         = "hotel-devops-tfstate-prod"
key            = "prod/terraform.tfstate"
region         = "ap-south-1"
dynamodb_table = "hotel-devops-tfstate-lock-prod"
encrypt        = true
